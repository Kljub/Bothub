# PFAD: /core/.env.example
NODE_ENV=production
DASHBOARD_BASE_URL=http://127.0.0.1
APP_KEY=

# Port for the core HTTP server.
# Set to a number (e.g. 3000) or "auto" / 0 to let the OS pick a free port.
# When using auto, RUNNER_ENDPOINT must contain the correct host — the port
# will be replaced automatically after binding.
CORE_PORT=3000

RUNNER_NAME=bothub-core-1
RUNNER_ENDPOINT=http://127.0.0.1:3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=

# Port for the standalone updater/installer process (core/update/installer.js)
# Default: 3099
UPDATER_PORT=3099

# Absolute path to the soundboard storage directory on this machine.
# Must match the path where the PHP dashboard stores uploaded sounds.
# Example: /var/www/BotHub/storage/soundboard
SOUNDBOARD_STORAGE_PATH=
